{
  "realm": "gridwatch",
  "enabled": true,
  "clientScopes": [
    {
      "name": "operator",
      "description": "Operator scope",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true"
      },
      "protocolMappers": [
        {
          "name": "operator_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "operator_id",
            "claim.name": "operator_id",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "defaultDefaultClientScopes": [
    "role_list",
    "profile",
    "email",
    "operator"
  ],
  "clients": [
    {
      "clientId": "gridwatch-api",
      "enabled": true,
      "bearerOnly": true,
      "protocol": "openid-connect"
    },
    {
      "clientId": "gridwatch-frontend",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["http://localhost:5173/*"],
      "webOrigins": ["+", "http://localhost:5173"],
      "protocol": "openid-connect"
    }
  ],
  "users": [
    {
      "username": "acme-admin",
      "enabled": true,
      "credentials": [
        { "type": "password", "value": "admin", "temporary": false }
      ],
      "attributes": {
        "operator_id": ["acme-charge"]
      }
    },
    {
      "username": "stadt-admin",
      "enabled": true,
      "credentials": [
        { "type": "password", "value": "admin", "temporary": false }
      ],
      "attributes": {
        "operator_id": ["stadtwerke-ev"]
      }
    }
  ]
}
